{
	"extends": "../../packages/preview/tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"rootDir": "../..",
		"types": ["node", "react", "react-dom", "vitest/globals"],
		"paths": {
			"@loom-dev/compiler": ["../../packages/compiler/wrapper.d.ts"],
			"@loom-dev/preview-engine": ["../../packages/preview-engine/src/index.ts"],
