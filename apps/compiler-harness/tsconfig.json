{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"baseUrl": ".",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"paths": {
			"@loom-dev/compiler": ["../../packages/compiler/wrapper.d.ts"],
			"@loom-dev/compiler/wasm": ["../../packages/compiler/wrapper.d.ts"]
		},
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"types": ["node"]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"src/**/*.d.ts",
		"src/vite-env.d.ts"
	],
	"exclude": ["src/generated/**/*"]
}
