{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@lattice-ui/compiler": ["../../packages/compiler/index.d.ts"],
      "@lattice-ui/preview-engine": ["../../packages/preview-engine/src/index.ts"],
      "@lattice-ui/preview-runtime": ["../../packages/preview-runtime/src/index.ts"]
    },
    "skipLibCheck": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "lattice.preview.config.ts",
    "vite.config.ts",
    "../../packages/preview/src/source/virtual-modules.d.ts"
  ],
  "exclude": ["src/generated/**/*"]
}
