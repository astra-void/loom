{
	"name": "@loom-dev/preview-analysis",
	"version": "0.1.0",
	"private": false,
	"description": "WASM-backed preview graph traversal and trace engine for Loom.",
	"main": "pkg/preview_analysis.js",
	"types": "pkg/preview_analysis.d.ts",
	"files": [
		"pkg/preview_analysis.d.ts",
		"pkg/preview_analysis.js",
		"pkg/preview_analysis_bg.js",
		"pkg/preview_analysis_bg.wasm",
		"pkg/preview_analysis_bg.wasm.d.ts",
		"README.md"
	],
	"scripts": {
		"build:native": "node ../../scripts/run-wasm-pack.mjs build --target nodejs --out-dir pkg",
		"build": "node ../../scripts/run-wasm-pack.mjs build --target nodejs --out-dir pkg",
		"build:release": "node ../../scripts/run-wasm-pack.mjs build --release --target nodejs --out-dir pkg",
		"build:rust": "cargo build",
		"format": "cargo fmt --all",
		"lint": "cargo fmt --all --check && cargo check",
		"lint:fix": "cargo fmt --all",
		"prepack": "node ../../scripts/run-wasm-pack.mjs build --release --target nodejs --out-dir pkg",
		"test": "cargo test"
	},
	"exports": {
		".": {
			"types": "./pkg/preview_analysis.d.ts",
			"import": "./pkg/preview_analysis.js",
			"require": "./pkg/preview_analysis.js",
			"default": "./pkg/preview_analysis.js"
		},
		"./preview_analysis_bg.wasm": "./pkg/preview_analysis_bg.wasm"
	}
}
