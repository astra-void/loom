{
	"name": "@loom-dev/layout-engine",
	"version": "0.1.0-alpha.2",
	"private": false,
	"description": "WASM layout engine for Loom previews.",
	"main": "pkg/layout_engine.js",
	"types": "pkg/layout_engine.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/astra-void/loom"
	},
	"files": [
		"pkg/layout_engine.d.ts",
		"pkg/layout_engine.js",
		"pkg/layout_engine_bg.js",
		"pkg/layout_engine_bg.wasm",
		"pkg/layout_engine_bg.wasm.d.ts"
	],
	"scripts": {
		"build:native": "node ../../scripts/run-wasm-pack.mjs build --target web --out-dir pkg",
		"build": "node ../../scripts/run-wasm-pack.mjs build --target web --out-dir pkg",
		"build:release": "node ../../scripts/run-wasm-pack.mjs build --release --target web --out-dir pkg",
		"build:rust": "cargo build",
		"format": "pnpm exec biome format --write .",
		"lint": "pnpm exec biome check .",
		"lint:fix": "pnpm exec biome check --write --unsafe .",
		"prepack": "node ../../scripts/run-wasm-pack.mjs build --release --target web --out-dir pkg",
		"test": "cargo test"
	},
	"exports": {
		".": {
			"types": "./pkg/layout_engine.d.ts",
			"import": "./pkg/layout_engine.js",
			"default": "./pkg/layout_engine.js"
		},
		"./layout_engine_bg.wasm": "./pkg/layout_engine_bg.wasm"
	},
	"module": "pkg/layout_engine.js",
	"type": "module"
}
