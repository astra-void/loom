{
	"name": "@loom-dev/preview",
	"version": "0.1.0-alpha.8",
	"private": false,
	"description": "Loom source-first preview build, server, and runtime package.",
	"main": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/astra-void/loom.git"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"postbuild": "tsx ./scripts/copy-assets.ts",
		"prebuild": "tsx ./scripts/clean-dist.ts",
		"format": "pnpm exec biome format --write .",
		"lint": "pnpm exec biome check .",
		"lint:fix": "pnpm exec biome check --write --unsafe .",
		"prepack": "pnpm run build",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"watch": "tsc -p tsconfig.json -w"
	},
	"dependencies": {
		"@loom-dev/compiler": "workspace:*",
		"@loom-dev/layout-engine": "workspace:*",
		"@loom-dev/preview-engine": "workspace:*",
		"@loom-dev/preview-runtime": "workspace:*",
		"@vitejs/plugin-react": "^6.0.1",
		"jsdom": "^29.0.2",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"vite": "^8.0.8",
		"vite-plugin-top-level-await": "^1.6.0",
		"vite-plugin-wasm": "^3.6.0"
	},
	"devDependencies": {
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"esbuild": "^0.28.0"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		},
		"./build": {
			"types": "./dist/build.d.ts",
			"import": "./dist/build.js",
			"default": "./dist/build.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js",
			"default": "./dist/client.js"
		},
		"./config": {
			"types": "./dist/config.d.ts",
			"import": "./dist/config.js",
			"default": "./dist/config.js"
		},
		"./headless": {
			"types": "./dist/headless.d.ts",
			"import": "./dist/headless.js",
			"default": "./dist/headless.js"
		},
		"./progress": {
			"types": "./dist/progress.d.ts",
			"import": "./dist/progress.js",
			"default": "./dist/progress.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js",
			"default": "./dist/server.js"
		},
		"./vite": {
			"types": "./dist/vite.d.ts",
			"import": "./dist/vite.js",
			"default": "./dist/vite.js"
		}
	}
}
