{
	"name": "@loom-dev/preview",
	"version": "0.1.0-alpha.2",
	"private": false,
	"description": "Loom source-first preview build, server, and runtime package.",
	"main": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/astra-void/loom.git"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"postbuild": "node ./scripts/copy-assets.mjs",
		"prebuild": "node ./scripts/clean-dist.mjs",
		"format": "pnpm exec biome format --write .",
		"lint": "pnpm exec biome check .",
		"lint:fix": "pnpm exec biome check --write --unsafe .",
		"prepack": "pnpm run build",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"watch": "tsc -p tsconfig.json -w"
	},
	"dependencies": {
		"@loom-dev/compiler": "workspace:*",
		"@loom-dev/layout-engine": "workspace:*",
		"@loom-dev/preview-engine": "workspace:*",
		"@loom-dev/preview-runtime": "workspace:*",
		"@vitejs/plugin-react": "^5.1.4",
		"jsdom": "^28.1.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"vite": "^7.3.1",
		"vite-plugin-top-level-await": "^1.6.0",
		"vite-plugin-wasm": "^3.5.0"
	},
	"devDependencies": {
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"esbuild": "^0.27.3"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		},
		"./config": {
			"types": "./dist/config.d.ts",
			"import": "./dist/config.js",
			"default": "./dist/config.js"
		},
		"./vite": {
			"types": "./dist/vite.d.ts",
			"import": "./dist/vite.js",
			"default": "./dist/vite.js"
		}
	}
}
