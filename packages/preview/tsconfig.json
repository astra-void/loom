{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"rootDir": "src",
		"outDir": "dist",
		"declaration": true,
		"jsx": "react-jsx",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["node", "react", "react-dom"]
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"]
}
