{
	"name": "loom-dev",
	"version": "0.1.0-alpha.8",
	"private": false,
	"description": "CLI for the Loom preview and build toolchain.",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/astra-void/loom.git"
	},
	"bin": {
		"loom": "dist/index.js"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"prebuild": "tsx ./scripts/clean-dist.ts",
		"format": "pnpm exec biome format --write .",
		"lint": "pnpm exec biome check .",
		"lint:fix": "pnpm exec biome check --write --unsafe .",
		"prepack": "pnpm run build",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"watch": "tsc -p tsconfig.json -w"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@loom-dev/preview": "workspace:*"
	}
}
