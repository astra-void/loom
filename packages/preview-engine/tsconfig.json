{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "node16",
		"moduleResolution": "node16",
		"rootDir": "src",
		"outDir": "dist",
		"declaration": true,
		"sourceMap": true,
		"inlineSources": true,
		"lib": ["ES2022", "DOM"],
