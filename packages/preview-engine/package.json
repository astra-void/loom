{
	"name": "@loom-dev/preview-engine",
	"version": "0.1.0-alpha.8",
	"private": false,
	"description": "Core preview engine protocols, discovery, and invalidation for Loom.",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/astra-void/loom.git"
	},
	"files": [
		"dist",
		"schemas",
		"README.md"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"prebuild": "tsx ./scripts/clean-dist.ts",
		"format": "pnpm exec biome format --write .",
		"lint": "pnpm exec biome check .",
		"lint:fix": "pnpm exec biome check --write --unsafe .",
		"prepack": "pnpm run build",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"watch": "tsc -p tsconfig.json -w"
	},
	"dependencies": {
		"@loom-dev/compiler": "workspace:*",
		"@loom-dev/preview-analysis": "workspace:*",
		"@loom-dev/preview-runtime": "workspace:*"
	},
	"devDependencies": {
		"@types/react": "^19.2.14",
		"typescript": "6.0.2"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./engine": {
			"types": "./dist/engine.d.ts",
			"import": "./dist/engine.js",
			"default": "./dist/engine.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js",
			"default": "./dist/types.js"
		},
		"./workspaceGraph": {
			"types": "./dist/workspaceGraph.d.ts",
			"import": "./dist/workspaceGraph.js",
			"default": "./dist/workspaceGraph.js"
		},
		"./schemas/diagnostic": "./schemas/diagnostic.schema.json",
		"./schemas/entry-payload": "./schemas/entry-payload.schema.json",
		"./schemas/workspace-index": "./schemas/workspace-index.schema.json"
	},
	"module": "dist/index.js"
}
