{
  "name": "@lattice-ui/preview-runtime",
  "version": "0.4.0",
  "private": false,
  "description": "Shared browser runtime for Lattice UI previews, including Roblox globals and DOM host rendering.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "schemas",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prebuild": "node ./scripts/clean-dist.mjs",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watch": "tsc -p tsconfig.json -w"
  },
  "dependencies": {
    "@lattice-ui/layout-engine": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schemas/layout-debug-payload": "./schemas/layout-debug-payload.schema.json",
    "./schemas/runtime-issue": "./schemas/runtime-issue.schema.json"
  },
  "module": "dist/index.js"
}
