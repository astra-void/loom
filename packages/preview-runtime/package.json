{
	"name": "@loom-dev/preview-runtime",
	"version": "0.1.0-alpha.2",
	"private": false,
	"description": "Shared browser runtime for Loom previews, including Roblox globals and DOM host rendering.",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"schemas",
		"src",
		"README.md"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"prebuild": "node ./scripts/clean-dist.mjs",
		"format": "pnpm exec biome format --write .",
		"lint": "pnpm exec biome check .",
		"lint:fix": "pnpm exec biome check --write --unsafe .",
		"prepack": "pnpm run build",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"watch": "tsc -p tsconfig.json -w"
	},
	"dependencies": {
		"@loom-dev/layout-engine": "workspace:*",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./schemas/layout-debug-payload": "./schemas/layout-debug-payload.schema.json",
		"./schemas/runtime-issue": "./schemas/runtime-issue.schema.json"
	},
	"module": "dist/index.js"
}
