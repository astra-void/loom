{
	"name": "@loom-dev/compiler",
	"version": "0.1.0-alpha.6",
	"private": false,
	"description": "Custom TSX compiler bridge using Rust, SWC, and NAPI-RS.",
	"main": "wrapper.js",
	"types": "wrapper.d.ts",
	"module": "wrapper.mjs",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/astra-void/loom.git"
	},
	"files": [
		"wrapper.js",
		"wrapper.d.ts",
		"wrapper.mjs",
		"sync.mjs",
		"sync.d.ts",
		"wasm.mjs",
		"index.js",
		"index.d.ts",
		"wasm/compiler.js",
		"wasm/compiler.d.ts",
		"wasm/compiler_bg.wasm",
		"wasm/compiler_bg.wasm.d.ts"
	],
	"exports": {
		".": {
			"types": "./wrapper.d.ts",
			"browser": "./wasm.mjs",
			"import": "./wrapper.mjs",
			"require": "./wrapper.js",
			"default": "./wrapper.mjs"
		},
		"./wasm": {
			"types": "./wrapper.d.ts",
			"browser": "./wasm.mjs",
			"import": "./wasm.mjs",
			"default": "./wasm.mjs"
		},
		"./sync": {
			"types": "./sync.d.ts",
			"import": "./sync.mjs",
			"default": "./sync.mjs"
		}
	},
	"napi": {
		"binaryName": "loom_compiler",
		"targets": [
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-unknown-linux-gnu",
			"x86_64-pc-windows-msvc",
			"x86_64-unknown-linux-musl",
			"aarch64-unknown-linux-gnu",
			"aarch64-unknown-linux-musl",
			"aarch64-pc-windows-msvc"
		]
	},
	"scripts": {
		"artifacts": "tsx ./scripts/build-artifacts.ts",
		"build:native": "tsx ./scripts/build-native.ts",
		"build:wasm": "tsx ./scripts/build-wasm.ts",
		"build": "pnpm run build:native && pnpm run build:wasm",
		"build:release:wasm": "tsx ./scripts/build-release-wasm.ts",
		"build:release": "tsx ./scripts/build-release.ts",
		"build:release:native": "tsx ./scripts/build-release-native.ts",
		"clean": "tsx ./scripts/clean.ts",
		"format": "pnpm exec biome format --write .",
		"create-npm-dirs": "napi create-npm-dirs --npm-dir ./npm",
		"lint": "pnpm exec biome check .",
		"lint:fix": "pnpm exec biome check --write --unsafe .",
		"prepack": "pnpm run build:release",
		"prepublish:napi": "pnpm run stage:napi",
		"publish:napi": "tsx ./scripts/publish-napi.ts",
		"publish:napi:dry-run": "tsx ./scripts/publish-napi.ts --dry-run",
		"stage:napi": "tsx ./scripts/publish-napi.ts --prepare-only",
		"watch": "napi build --platform --watch"
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.6.1"
	}
}
