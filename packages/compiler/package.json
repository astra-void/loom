{
	"name": "@loom-dev/compiler",
	"version": "0.1.0",
	"private": false,
	"description": "Custom TSX compiler bridge using Rust, SWC, and NAPI-RS.",
	"main": "wrapper.js",
	"types": "wrapper.d.ts",
	"module": "wrapper.mjs",
	"files": [
		"wrapper.js",
		"wrapper.d.ts",
		"wrapper.mjs",
		"index.js",
		"index.d.ts"
	],
	"exports": {
		".": {
			"types": "./wrapper.d.ts",
			"import": "./wrapper.mjs",
			"require": "./wrapper.js",
			"default": "./wrapper.mjs"
		}
	},
	"napi": {
		"binaryName": "loom_compiler",
		"targets": [
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-unknown-linux-gnu",
			"x86_64-pc-windows-msvc",
			"x86_64-unknown-linux-musl",
			"aarch64-unknown-linux-gnu",
			"aarch64-unknown-linux-musl",
			"aarch64-pc-windows-msvc"
		]
	},
	"scripts": {
		"artifacts": "napi artifacts --output-dir ./artifacts --npm-dir ./npm",
		"build": "napi build --platform",
		"build:release": "node ./scripts/build-release.mjs",
		"build:release:native": "node ./scripts/build-release-native.mjs",
		"create-npm-dirs": "napi create-npm-dirs --npm-dir ./npm",
		"prepack": "pnpm run build:release:native",
		"prepublish:napi": "pnpm run stage:napi",
		"publish:napi": "node ./scripts/publish-napi.mjs",
		"publish:napi:dry-run": "node ./scripts/publish-napi.mjs --dry-run",
		"stage:napi": "node ./scripts/publish-napi.mjs --prepare-only",
		"watch": "napi build --platform --watch"
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.5.1"
	}
}
