{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"module": "node16",
		"moduleResolution": "node16",
		"outDir": ".",
		"rootDir": ".",
		"target": "ES2021",
		"lib": ["ES2021"],
		"types": ["node"]
	},
	"include": ["wrapper.js"],
	"exclude": [".native", "node_modules", "target"]
}
