{
	"$schema": "https://turborepo.dev/schema.json",
	"globalDependencies": [
		"package.json",
		"pnpm-lock.yaml",
		"pnpm-workspace.yaml",
		"biome.json",
		"tsconfig.base.json",
		"scripts/**"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "!**/.turbo/**", "!**/.native/**"],
			"outputLogs": "new-only",
			"outputs": [
				"dist/**",
				"pkg/**",
				"wasm/**",
				"wasm.mjs",
				"index.js",
				"index.d.ts",
				"wrapper.d.ts"
			]
		},
		"build:native": {
			"env": ["LOOM_NATIVE_TARGET"],
			"inputs": ["$TURBO_DEFAULT$", "!**/.turbo/**", "!**/.native/**"],
			"outputLogs": "new-only",
			"outputs": [
				"dist/**",
				"pkg/**",
				".native/manifest.json",
				".native/local/*.node",
				"index.js",
				"index.d.ts",
				"wrapper.d.ts"
			]
		},
		"build:packages": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "!**/.turbo/**", "!**/.native/**"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"format": {
			"cache": false,
			"outputs": []
		},
		"lint": {
			"outputs": []
		},
		"lint:fix": {
			"cache": false,
			"outputs": []
		},
		"test": {
			"dependsOn": ["build"],
			"outputs": []
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"verify:dts": {
			"dependsOn": ["build"],
			"outputs": []
		}
	}
}
